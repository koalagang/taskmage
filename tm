# :command.parse_requirements
parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        tm_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.environment_variables_filter

  env_var_names+=("TASKMAGE_TODOFILE")
  env_var_names+=("TASKMAGE_DONEFILE")
  env_var_names+=("TASKMAGE_DELETEDFILE")
  if [[ -z "${TASKMAGE_TODOFILE:-}" ]]; then
    printf "missing required environment variable: TASKMAGE_TODOFILE\n" >&2
    exit 1
  fi
  if [[ -z "${TASKMAGE_DONEFILE:-}" ]]; then
    printf "missing required environment variable: TASKMAGE_DONEFILE\n" >&2
    exit 1
  fi
  if [[ -z "${TASKMAGE_DELETEDFILE:-}" ]]; then
    printf "missing required environment variable: TASKMAGE_DELETEDFILE\n" >&2
    exit 1
  fi

  # :command.dependencies_filter
  missing_deps=
  # :dependency.filter
  if ! command -v cat >/dev/null 2>&1; then
    printf "missing dependency: cat\n" >&2
    printf "%s\n\n" "taskmage depends on the GNU coreutils" >&2
    missing_deps=1
  else
    deps['cat']="$(command -v cat | head -n1)"
  fi

  # :dependency.filter
  if ! command -v sed >/dev/null 2>&1; then
    printf "missing dependency: sed\n" >&2
    printf "%s\n\n" "taskmage depends on the GNU coreutils" >&2
    missing_deps=1
  else
    deps['sed']="$(command -v sed | head -n1)"
  fi

  # :dependency.filter
  if ! command -v grep >/dev/null 2>&1; then
    printf "missing dependency: grep\n" >&2
    printf "%s\n\n" "taskmage depends on the GNU coreutils" >&2
    missing_deps=1
  else
    deps['grep']="$(command -v grep | head -n1)"
  fi

  # :dependency.filter
  if ! command -v date >/dev/null 2>&1; then
    printf "missing dependency: date\n" >&2
    printf "%s\n\n" "taskmage depends on the GNU coreutils" >&2
    missing_deps=1
  else
    deps['date']="$(command -v date | head -n1)"
  fi

  # :dependency.filter
  if ! command -v echo >/dev/null 2>&1; then
    printf "missing dependency: echo\n" >&2
    printf "%s\n\n" "taskmage depends on the GNU coreutils" >&2
    missing_deps=1
  else
    deps['echo']="$(command -v echo | head -n1)"
  fi

  # :dependency.filter
  if ! command -v wc >/dev/null 2>&1; then
    printf "missing dependency: wc\n" >&2
    printf "%s\n\n" "taskmage depends on the GNU coreutils" >&2
    missing_deps=1
  else
    deps['wc']="$(command -v wc | head -n1)"
  fi

  # :dependency.filter
  if ! command -v tput >/dev/null 2>&1; then
    printf "missing dependency: tput\n" >&2
    printf "%s\n\n" "taskmage depends on ncurses" >&2
    missing_deps=1
  else
    deps['tput']="$(command -v tput | head -n1)"
  fi

  # :dependency.filter
  if ! command -v column >/dev/null 2>&1; then
    printf "missing dependency: column\n" >&2
    printf "%s\n\n" "taskmage depends on util-linux" >&2
    missing_deps=1
  else
    deps['column']="$(command -v column | head -n1)"
  fi

  if [[ -n $missing_deps ]]; then
    exit 1
  fi

  # :command.command_filter
  action=${1:-}

  case $action in

    add | a)
      action="add"
      shift
      tm_add_parse_requirements "$@"
      shift $#
      ;;

    list | ls | l)
      action="list"
      shift
      tm_list_parse_requirements "$@"
      shift $#
      ;;

    done | d | finish | f)
      action="done"
      shift
      tm_done_parse_requirements "$@"
      shift $#
      ;;

    delete | del | remove | rm)
      action="delete"
      shift
      tm_delete_parse_requirements "$@"
      shift $#
      ;;

    purge | p)
      action="purge"
      shift
      tm_purge_parse_requirements "$@"
      shift $#
      ;;

    archive | x)
      action="archive"
      shift
      tm_archive_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    *)
      action="list"
      tm_list_parse_requirements "$@"
      shift $#
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

# :command.parse_requirements
tm_add_parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        tm_add_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action="add"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_repeatable
        # :argument.case_repeatable
        escaped="$(printf '%q' "$1")"
        if [[ -z ${args['task']+x} ]]; then
          args['task']="$escaped"
        else
          args['task']="${args['task']} $escaped"

        fi
        shift

        ;;

    esac
  done

  # :command.required_args_filter
  if [[ -z ${args['task']+x} ]]; then
    printf "missing required argument: TASK\nusage: tm add TASK...\n" >&2

    exit 1
  fi

}

# :command.parse_requirements
tm_list_parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        tm_list_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action="list"

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        # :argument.case
        if [[ -z ${args['task_list']+x} ]]; then
          args['task_list']=$1
          shift
        else
          printf "invalid argument: %s\n" "$key" >&2
          exit 1
        fi

        ;;

    esac
  done

  # :command.whitelist_filter
  if [[ -n ${args['task_list']:-} ]] && [[ ! ${args['task_list']:-} =~ ^(all|a|archived|x|complete|c|deleted|del|removed|rm|pending|p|done|d)$ ]]; then
    printf "%s\n" "task_list must be one of: all, a, archived, x, complete, c, deleted, del, removed, rm, pending, p, done, d" >&2
    exit 1
  fi

}

